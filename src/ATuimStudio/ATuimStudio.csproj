		<PackageReference Condition="'$(Configuration)' == 'Debug'" Include="Avalonia.Diagnostics" />
		<PackageReference Include="Microsoft.Extensions.DependencyInjection" />
		<PackageReference Include="Dock.Avalonia" />
		<PackageReference Include="Dock.Avalonia.Themes.Fluent" />
		<PackageReference Include="Dock.Model.Avalonia" />
		<PackageReference Include="Dock.Model.Mvvm" />
		<PackageReference Include="Avalonia.AvaloniaEdit" />
		<PackageReference Include="AvaloniaEdit.TextMate" />
		<PackageReference Include="Microsoft.Extensions.ObjectPool" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\ATuimStudio.Common\ATuimStudio.Common.csproj" />
		<ProjectReference Include="..\ATuimStudio.Extensions.Build.Ui\ATuimStudio.Extensions.Build.Ui.csproj" />
		<ProjectReference Include="..\ATuimStudio.Extensions.Core.Abstractions\ATuimStudio.Extensions.Core.Abstractions.csproj" />
		<ProjectReference Include="..\ATuimStudio.Extensions.Core.Sqlite\ATuimStudio.Extensions.Core.Sqlite.csproj" />
		<ProjectReference Include="..\ATuimStudio.Extensions.Core.Ui.Abstractions\ATuimStudio.Extensions.Core.Ui.Abstractions.csproj" />
		<ProjectReference Include="..\ATuimStudio.Extensions.Core\ATuimStudio.Extensions.Core.csproj" />
		<ProjectReference Include="..\ATuimStudio.Extensions.Debug.Ui\ATuimStudio.Extensions.Debug.Ui.csproj" />
		<ProjectReference Include="..\ATuimStudio.Extensions.Git.Ui\ATuimStudio.Extensions.Git.Ui.csproj" />
		<ProjectReference Include="..\ATuimStudio.Extensions.TextEditCompletion.Ui\ATuimStudio.Extensions.TextEditCompletion.Ui.csproj" />
	</ItemGroup>
