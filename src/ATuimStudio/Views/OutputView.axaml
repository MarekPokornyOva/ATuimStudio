<UserControl x:Class="ATuimStudio.Views.OutputView"
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:vm="using:ATuimStudio.ViewModels"
		xmlns:m="using:ATuimStudio.Models"
		mc:Ignorable="d"
		d:DesignWidth="300" d:DesignHeight="400"
		x:DataType="vm:OutputViewModel" x:CompileBindings="True">
	<Design.DataContext>
		<vm:OutputViewModel />
	</Design.DataContext>

	<StackPanel>
		<ComboBox ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}">
			<ComboBox.ItemTemplate>
				<DataTemplate>
					<TextBlock Text="{Binding}"/>
				</DataTemplate>
			</ComboBox.ItemTemplate>
		</ComboBox>
		<ScrollViewer HorizontalScrollBarVisibility="Auto">
			<ItemsRepeater ItemsSource="{Binding Records}" >
				<ItemsRepeater.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding Message}"/>
					</DataTemplate>
				</ItemsRepeater.ItemTemplate>
			</ItemsRepeater>
		</ScrollViewer>
	</StackPanel>
</UserControl>
