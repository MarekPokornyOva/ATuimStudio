<UserControl x:Class="ATuimStudio.Views.SolutionView"
		xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:vm="using:ATuimStudio.ViewModels"
		xmlns:m="using:ATuimStudio.Models"
		mc:Ignorable="d"
		d:DesignWidth="300" d:DesignHeight="400"
		x:DataType="vm:SolutionViewModel" x:CompileBindings="True">
	<Design.DataContext>
		<vm:SolutionViewModel />
	</Design.DataContext>

	<UserControl.KeyBindings>
		<KeyBinding Gesture="Delete" Command="{Binding DeleteFileCommand}" />
		<KeyBinding Gesture="Ctrl+Shift+A" Command="{Binding NewFileCommand}" />
	</UserControl.KeyBindings>

	<TreeView ItemsSource="{Binding SolutionNodes}" SelectedItem="{Binding SelectedItem}" BorderBrush="White" BorderThickness="2">
		<TreeView.Styles>
			<Style Selector="TreeViewItem">
				<Setter Property="IsExpanded" Value="{Binding IsExpanded}" x:DataType="m:SolutionDataNode"/>
			</Style>
		</TreeView.Styles>
		<TreeView.DataTemplates>
			<TreeDataTemplate DataType="m:SolutionDataNode" ItemsSource="{Binding Children}">
				<TextBlock Text="{Binding Title}" Padding="0" Margin="0"/>
			</TreeDataTemplate>
		</TreeView.DataTemplates>
	</TreeView>

</UserControl>
