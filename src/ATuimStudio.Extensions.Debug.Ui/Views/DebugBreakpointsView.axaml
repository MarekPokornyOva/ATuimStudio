<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:ATuimStudio.Extensions.Debug"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="ATuimStudio.Extensions.Debug.DebugBreakpointsView"
			 x:DataType="vm:DebugBreakpointsViewModel">
	<Design.DataContext>
		<vm:DebugBreakpointsViewModel />
	</Design.DataContext>

	<ScrollViewer HorizontalScrollBarVisibility="Auto">
		<ListBox ItemsSource="{Binding Breakpoints}">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="{Binding Filepath}" Margin="0 0 10 0"/>
						<TextBlock Text="{Binding Range.Start.Line}"/>
						<TextBlock Text=":"/>
						<TextBlock Text="{Binding Range.Start.Column}"/>
					</StackPanel>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</ScrollViewer>
</UserControl>
